{
  "include": [
    "src",
    "main.py"
  ],
  "exclude": [
    "**/node_modules",
    "**/__pycache__",
    ".git",
    ".venv",
    "venv",
    "build",
    "dist",
    "*.egg-info",
    "src/core/http2"
  ],
  "pythonVersion": "3.13",
  "pythonPlatform": "Linux",
  "typeCheckingMode": "basic",
  "strict": [
    "src/core",
    "src/config"
  ],
  "reportMissingTypeStubs": false,
  "reportUnnecessaryTypeIgnoreComment": false,
  "executionEnvironments": [
    {
      "root": ".",
      "extraPaths": ["."]
    }
  ]
}

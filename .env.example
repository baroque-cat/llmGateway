# Database Configuration
DB_HOST=localhost # change to "database" in .env for Docker
DB_PORT=5432
DB_USER=llm_gateway
DB_PASSWORD=your_secure_password_here
DB_NAME=llmgateway

# Gateway Configuration
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=55300
GATEWAY_WORKERS=4

# Keeper Configuration
KEEPER_METRICS_PORT=9090

# Metrics Configuration
METRICS_ACCESS_TOKEN=your_secure_metrics_token_here
METRICS_BACKEND=       # "prometheus" or "" (memory/disabled) — read directly by metrics subsystem
PROMETHEUS_MULTIPROC_DIR=  # set for keeper multiprocess mode, unset for gateway

# Provider Defaults (used when provider config does not specify its own token)
LLM_PROVIDER_DEFAULT_TOKEN=

# Provider-specific tokens (set if using these providers)
GEMINI_PROD_TOKEN=
DEEPSEEK_TOKEN=
ANTHROPIC_TOKEN=
QWEN_HOME_TOKEN=
